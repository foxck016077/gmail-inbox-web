# Copy to .env.local for local dev, paste into Vercel project settings for prod.

# Google OAuth 2.0 client (Web application type) from Google Cloud Console.
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# 32+ char random string. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Set to your deploy URL in production (https://yourdomain.com).
# Leave unset for local dev — NextAuth defaults to http://localhost:3000.
# AUTH_URL=
